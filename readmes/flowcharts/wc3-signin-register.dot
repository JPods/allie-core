// WC3 Sign-in / Register — authentication and role assignment
// Render: dot -Tpdf wc3-signin-register.dot -o wc3-signin-register.pdf

digraph wc3_signin {
    rankdir=TB
    fontname="Helvetica"
    fontsize=11
    node [fontname="Helvetica" fontsize=10 style=filled]
    edge [fontname="Helvetica" fontsize=8]
    label="WC3 — Sign-in / Register Flow\nRoles: ADMIN, USER, REP, VENDOR, SALES, CUSTOMER"
    labelloc=t
    fontsize=14
    pad=0.5

    // Entry
    splash [label="Splash" shape=box fillcolor="#F9E79F"]

    // Login
    login [label="Login\nUserName (email)\nPassword\nrole: \"USER\"" shape=box fillcolor="#FCF3CF"]

    // Register
    register [label="Register\nUserName (email)\nPassword\nrole: \"USER\"" shape=box fillcolor="#FCF3CF"]

    // Email
    email [label="Email\nconfirmation" shape=ellipse fillcolor="#5DADE2" fontcolor=white]

    // Entry page
    entry [label="Entry page\nname\naddress\nphone\netc...\nrole: \"USER\"" shape=parallelogram fillcolor="#F4D03F"]

    // OnSave
    onsave [label="OnSave\ncreate contact\nset role\ndtCreated\ndt...\nreferences\nmetadata" shape=parallelogram fillcolor="#F4D03F"]

    // Contact
    contact [label="contacts\nrole_default:\nreplaces USER\nas applicable" shape=box fillcolor="#82E0AA"]

    // Admin
    admin [label="ADMIN\ncan add roles" shape=diamond fillcolor="#E74C3C" fontcolor=white fontsize=9]

    // Roles
    roles [label="List of roles\nassigned in backend.\ncontact can select from\nassigned roles in \"profile\"\nlayout\n\nADMIN\nUSER\nREP\nVENDOR\nSALES\nCUSTOMER" shape=box fillcolor="#F2F3F4" fontsize=8]

    // Active
    active [label="active" shape=diamond fillcolor="#5DADE2" fontcolor=white]

    // Role entities
    customers_ent [label="customers" shape=box fillcolor="#82E0AA"]
    employees_ent [label="employees" shape=box fillcolor="#82E0AA"]
    reps_ent [label="reps" shape=box fillcolor="#82E0AA"]
    vendors_ent [label="vendors" shape=box fillcolor="#82E0AA"]

    // References
    refs [label="references id\ncustomers\nvendors\nemployees\nreps" shape=note fillcolor="#FDFEFE" fontsize=9]

    // Role note
    role_note [label="role: \"USER\"\ninput hidden\nnot important at this point" shape=note fillcolor="#FDFEFE" fontsize=8 fontcolor="#E74C3C"]

    // Edges
    splash -> login
    splash -> register
    register -> email
    email -> contact [style=dashed]
    register -> entry [style=dashed]
    entry -> onsave
    onsave -> contact
    login -> contact

    contact -> roles
    admin -> roles [label="can assign"]
    contact -> active

    active -> customers_ent
    active -> employees_ent
    active -> reps_ent
    active -> vendors_ent

    contact -> refs [label="linked by id\nin references" style=dashed]

    register -> role_note [style=dotted]
}
