// WC3 QA Entity — Quality Assurance question/answer pattern
// Linkage references any record; QAQuestion defines the survey; QA holds answers
// Render: dot -Tpdf wc3-qa-entity.dot -o wc3-qa-entity.pdf

digraph wc3_qa {
    rankdir=TB
    fontname="Helvetica"
    fontsize=11
    node [fontname="Helvetica" fontsize=10 style=filled]
    edge [fontname="Helvetica" fontsize=8]
    label="WC3 — QA Entity\nQuality inspection, surveys, customer feedback"
    labelloc=t
    fontsize=14
    pad=0.5

    // Linkage
    linkage [label="LinkageEntry\n\nshared by lines\nrelated data\nspecs\ndata at time of action" shape=box fillcolor="#82E0AA"]

    // Reference
    linkage_ref [label="LinkageEntry.reference\n\ntableName\nidNum\nreason\netc..." shape=note fillcolor="#FDFEFE" fontsize=9]

    // Any record
    any_record [label="Any or multiple\ntablenames/collections\nrecord/document" shape=box fillcolor="#E59866" fontcolor=white fontsize=10]

    // Record types
    customer [label="Customer" shape=box fillcolor="#F4D03F"]
    vendor [label="Vendor" shape=box fillcolor="#E59866"]
    proposals [label="Proposals" shape=box fillcolor="#FCF3CF"]
    sos [label="SOs" shape=box fillcolor="#ABEBC6"]
    pos [label="POs" shape=box fillcolor="#D6EAF8"]
    item_rec [label="Item" shape=box fillcolor="#E8DAEF"]
    dots [label="..." shape=box fillcolor="#F2F3F4"]

    // Lines that connect
    prop_line [label="Proposal.line" shape=box fillcolor="#D5F5E3" fontsize=9]
    so_line [label="SO.line" shape=box fillcolor="#D5F5E3" fontsize=9]
    inv_line [label="Invoice.line" shape=box fillcolor="#FADBD8" fontsize=9]
    po_line [label="PO.line" shape=box fillcolor="#D6EAF8" fontsize=9]

    // QA Question template
    qa_question [label="QAQuestion\n\nSet of questions to be\nanswered with list of\ndefault choices\n\n(Setting record\nor dedicated model)" shape=box fillcolor="#FCF3CF" fontsize=9]

    // QA answer record
    qa [label="QA\n\nQA.question\nQA.answer\nQA.sequence" shape=diamond fillcolor="#F4D03F" fontsize=10]

    // Selection
    select [label="Select the\ndesired answer" shape=note fillcolor="#FDFEFE" fontsize=9 fontcolor="#E74C3C"]

    // Creation note
    create_note [label="Create a QA for each\nQAQuestion relative to:\n\u2022 inspection\n\u2022 customer survey\n\u2022 Serial issue\n\u2022 etc..." shape=note fillcolor="#FDFEFE" fontsize=8 fontcolor="#E59866"]

    // Edges
    linkage -> linkage_ref
    linkage_ref -> any_record
    any_record -> customer [style=invis]
    any_record -> vendor [style=invis]
    any_record -> proposals [style=invis]
    any_record -> sos [style=invis]
    any_record -> pos [style=invis]
    any_record -> item_rec [style=invis]

    linkage -> prop_line [color="#27AE60"]
    linkage -> so_line [color="#27AE60"]
    linkage -> inv_line [color="#27AE60"]
    linkage -> po_line [color="#27AE60"]

    linkage -> qa [color="#E59866"]
    qa_question -> qa [label="defines\nquestions" color="#E59866"]
    qa -> select [color="#E74C3C"]
    qa -> create_note [style=invis]
}
