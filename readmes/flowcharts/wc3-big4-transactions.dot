// WC3 Big 4 Transactions — Proposals, Orders, Purchases, Invoices
// Shows line quantity fields and pending inventory flow
// Render: dot -Tpdf wc3-big4-transactions.dot -o wc3-big4-transactions.pdf

digraph wc3_big4 {
    rankdir=TB
    fontname="Helvetica"
    fontsize=11
    node [fontname="Helvetica" fontsize=10 style=filled]
    edge [fontname="Helvetica" fontsize=8]
    label="WC3 — Big 4 Transactions\nLine quantity flow and pending inventory"
    labelloc=t
    fontsize=14
    pad=0.5
    nodesep=0.8

    // Top
    contacts [label="contacts" shape=box fillcolor="#F9E79F"]
    customers [label="customers" shape=box fillcolor="#F4D03F"]
    vendors [label="vendors" shape=box fillcolor="#E59866"]

    // Linkage
    linkage [label="linkages\nshared by lines\nrelated data\nspecs\ndata at time of action" shape=box fillcolor="#82E0AA"]

    // Item
    item [label="items\nquantity.on_hand\nquantity.allocated\nquantity.available\nquantity.on_p\nquantity.on_so\nquantity.on_in\nquantity.on_po\nquantity.on_wo\nquantity.on_r" shape=box fillcolor="#7D3C98" fontcolor=white fontsize=9]

    // Pending
    pending [label="pending\n(PendingInventory\nAdjustment)" shape=box fillcolor="#922B21" fontcolor=white fontsize=9]

    // Big 4 transactions
    proposals [label="proposals" shape=box fillcolor="#FCF3CF"]
    orders [label="orders" shape=box fillcolor="#ABEBC6"]
    purchases [label="purchases" shape=box fillcolor="#D6EAF8"]
    invoices [label="invoices" shape=box fillcolor="#F5B7B1"]

    // Lines
    prop_line [label="lines\n\nid\nquantity.placed\nquantity.actioned\nquantity.remaining\nquantity.canceled\nitem_id" shape=box fillcolor="#FEF9E7" fontsize=8]

    order_line [label="lines\n\nid\nquantity.placed\nquantity.actioned\nquantity.remaining\nquantity.canceled\nitem_id" shape=box fillcolor="#D5F5E3" fontsize=8]

    purchase_line [label="lines\n\nid\nquantity.placed\nquantity.actioned\nquantity.remaining\nquantity.canceled\nquantity.received\nitem_id" shape=box fillcolor="#D6EAF8" fontsize=8]

    invoice_line [label="lines\n\nid\nquantity.placed\nquantity.actioned\nquantity.remaining\nquantity.canceled\nquantity.parent\nitem_id" shape=box fillcolor="#FADBD8" fontsize=8]

    // Receipts
    receipts [label="receipts\nvendor shipping\ndocument" shape=box fillcolor="#D6EAF8" fontsize=9]

    // Inventory layer
    inv_layer [label="inventory layer\n(consolidate with)\nreceipt_line\nquantity.on_hand\nby cost" shape=box fillcolor="#7D3C98" fontcolor=white fontsize=9]

    // Quantity rules
    rules [label="quantity.placed = input by user\nquantity.canceled affects quantity_ordered\nquantity.remaining = quantity_ordered - all child actions\n  \u2022 orders from proposals\n  \u2022 invoiced from orders\n  \u2022 invoices not packed\n  \u2022 purchases not received\nquantity.parent = parent's remaining when child created" shape=note fillcolor="#FDFEFE" fontsize=8]

    // Edges
    contacts -> customers [style=invis]
    customers -> proposals [color="#F39C12"]
    customers -> orders [color="#F39C12"]
    vendors -> purchases [color="#E59866"]
    orders -> invoices [color="#F39C12" style=dashed]

    proposals -> prop_line
    orders -> order_line
    purchases -> purchase_line
    invoices -> invoice_line

    // Line → id chains
    prop_line -> order_line [label="id→id" style=dashed]
    order_line -> invoice_line [label="id→id" style=dashed]

    // Pending inventory
    order_line -> pending [label="+on_so" color="#E59866"]
    purchase_line -> pending [label="+on_po" color="#E59866"]
    invoice_line -> pending [label="-on_hand\n-on_so" color="#E74C3C"]
    receipts -> pending [label="+on_hand\n-on_po" color="#27AE60"]
    pending -> item [color="#922B21"]

    // Receipts → inventory layer
    receipts -> inv_layer [color="#2980B9"]
    inv_layer -> item [style=dashed]

    // Linkage connects to lines
    linkage -> order_line [style=dashed color="#27AE60"]
    linkage -> purchase_line [style=dashed color="#27AE60"]
    linkage -> invoice_line [style=dashed color="#27AE60"]
}
