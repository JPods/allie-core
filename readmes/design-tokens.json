{
  "_note": "JPods + WebClerk shared design tokens. All UIs in this ecosystem draw from here. Claude Code must read this before building any UI component.",
  "_updated": "2026-04-29",

  "color": {
    "background":   "#0a0e1a",
    "surface":      "#141929",
    "surface_alt":  "#1c2338",
    "border":       "#2a3350",
    "text":         "#e8edf8",
    "muted":        "#7a87a8",

    "green":        "#3ddb6b",
    "amber":        "#f0b429",
    "red":          "#f45b5b",
    "blue":         "#4a9eff",

    "semantic": {
      "inbound":    "#f45b5b",
      "outbound":   "#4a9eff",
      "action":     "#3ddb6b",
      "warning":    "#f0b429",
      "error":      "#f45b5b",
      "confirm":    "#3ddb6b"
    },

    "_rules": [
      "Red (#f45b5b) = inbound (hot end). Never use red for outbound or decoration.",
      "Blue (#4a9eff) = outbound (cool end). Never use blue for inbound or decoration.",
      "Green (#3ddb6b) = primary action / confirm.",
      "Amber (#f0b429) = warning / attention. Not an error.",
      "These are law — see jpods-connection-point-rule.md and CLAUDE.md."
    ]
  },

  "spacing": {
    "xs":  "4px",
    "sm":  "8px",
    "md":  "16px",
    "lg":  "20px",
    "xl":  "32px",
    "xxl": "48px"
  },

  "border_radius": {
    "sm":   "6px",
    "md":   "12px",
    "lg":   "16px",
    "pill": "999px"
  },

  "font": {
    "family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "size": {
      "xs":    "11px",
      "sm":    "12px",
      "base":  "16px",
      "md":    "17px",
      "lg":    "18px",
      "xl":    "22px",
      "xxl":   "28px",
      "hero":  "38px"
    },
    "weight": {
      "normal": 400,
      "medium": 500,
      "bold":   700
    },
    "label": {
      "size":           "11px",
      "weight":         700,
      "letter_spacing": "0.1em",
      "transform":      "uppercase",
      "color":          "$color.muted"
    }
  },

  "shadow": {
    "none":   "none",
    "sm":     "0 1px 3px rgba(0,0,0,0.4)",
    "md":     "0 4px 12px rgba(0,0,0,0.5)",
    "glow_green": "0 0 12px rgba(61,219,107,0.25)",
    "glow_amber": "0 0 12px rgba(240,180,41,0.25)"
  },

  "motion": {
    "fast":   "0.1s",
    "normal": "0.15s",
    "slow":   "0.3s",
    "easing": "ease"
  },

  "max_width": {
    "phone":  "420px",
    "tablet": "768px",
    "desktop":"1200px"
  },

  "component": {
    "input": {
      "background":   "$color.surface",
      "border":       "1.5px solid $color.border",
      "border_focus": "1.5px solid $color.green",
      "border_radius":"$border_radius.md",
      "padding":      "14px 16px",
      "font_size":    "$font.size.md",
      "color":        "$color.text"
    },
    "button_primary": {
      "background":    "$color.green",
      "color":         "$color.background",
      "border":        "none",
      "border_radius": "$border_radius.md",
      "font_size":     "$font.size.lg",
      "font_weight":   "$font.weight.bold",
      "letter_spacing":"0.06em",
      "transform":     "uppercase",
      "padding":       "18px",
      "active_scale":  "0.98"
    },
    "button_secondary": {
      "background":    "$color.surface",
      "color":         "$color.text",
      "border":        "1.5px solid $color.border",
      "border_radius": "$border_radius.md",
      "padding":       "14px"
    },
    "card": {
      "background":    "$color.surface",
      "border":        "1px solid $color.border",
      "border_radius": "$border_radius.md",
      "padding":       "20px"
    },
    "card_success": {
      "background":    "rgba(61,219,107,0.08)",
      "border":        "1px solid $color.green",
      "border_radius": "$border_radius.md",
      "padding":       "20px"
    },
    "card_warning": {
      "background":    "rgba(240,180,41,0.10)",
      "border":        "1px solid $color.amber",
      "border_radius": "$border_radius.md",
      "padding":       "12px 14px"
    },
    "card_error": {
      "background":    "rgba(244,91,91,0.08)",
      "border":        "1px solid $color.red",
      "border_radius": "$border_radius.md",
      "padding":       "12px 14px"
    }
  }
}
