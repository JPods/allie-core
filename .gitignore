# Allie — Private Repository
# What stays local and never goes to GitHub

# API keys and live credentials — NEVER commit
config/allie_api_keys.json
config/wc_credentials.json

# Operational per-day logs — stay local
today/
logs/

# Non-repo files that landed in working directory
*.pdf
*.exe
LexarDataShield*/

# Training Modelfiles — local build artifacts
training/

# Inbox folder is eliminated — see readmes/path-list.md for document index
inbox/
# process/inbox/ is explicitly tracked — TF/DNW/TFTS captures feed Allie's nightly run
!process/inbox/
!process/inbox/**

# Large local knowledge base (too big for repo; path-list.md points to files)
knowledge/

# Raw source material and archives
sources/
archive/

# Allie's runtime internals — session state, logs, workspace, scratchpad
allie/carryon/
allie/inbox/
allie/logs/
allie/workspace/
allie/index/

# Athena's private key and trustee documents — NEVER commit
athena_private.pem
**/athena_private.pem
**/athena/escrow/
**/cred_names.txt

# Google OAuth credentials — NEVER commit (permanent tokens on Allie drive only)
credentials/

# credentials.enc IS committed — it is Athena-encrypted and safe in the private repo
# cred_names.txt IS committed — plaintext names only, no values

# Python virtual environments
.venv/
venv/
__pycache__/
*.pyc

# macOS
.DS_Store
**/.DS_Store
._*
**/._*
.TemporaryItems
**/.TemporaryItems
~$*
**/.Spotlight-V100/
**/.fseventsd/
**/.Trashes/

# Backup snapshots (large; Athena keeps these locally)
**/agents_backup/
