{
  "version": 1,
  "description": "Blind evaluation questions for vector store quality scoring. Written by Bill, NOT indexed by any store. Each question has an expected_source (the file/chunk that SHOULD be top result) and expected_keywords (terms that MUST appear in a correct answer).",
  "instructions_for_bill": "Add your own questions below. Think: what would a new WC3 user ask? What would a customer ask Alice? The store has never seen these questions — that's the point.",
  "questions": [
    {
      "id": "Q01",
      "store": "alice",
      "question": "How do I apply a payment to an invoice?",
      "expected_source": "test_payment_services.py",
      "expected_keywords": ["apply", "payment", "invoice", "totals.received", "balance"],
      "category": "billing"
    },
    {
      "id": "Q02",
      "store": "alice",
      "question": "What happens to inventory when I ship an order?",
      "expected_source": "inventory_flow_testing.md",
      "expected_keywords": ["on_hand", "on_so", "invoice", "decreases"],
      "category": "inventory"
    },
    {
      "id": "Q03",
      "store": "alice",
      "question": "How do I set up payment terms like Net 30?",
      "expected_source": "test_ledger.py",
      "expected_keywords": ["term", "N30", "ledger", "due"],
      "category": "billing"
    },
    {
      "id": "Q04",
      "store": "alice",
      "question": "What is the formula for available inventory?",
      "expected_source": "inventory_flow_testing.md",
      "expected_keywords": ["on_hand", "on_so", "on_po", "on_wo", "available"],
      "category": "inventory"
    },
    {
      "id": "Q05",
      "store": "alice",
      "question": "How do I convert an order to an invoice?",
